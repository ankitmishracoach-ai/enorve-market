# Environment Variables for Enorve Marketing Site
# Vite embeds VITE_* vars at build time. In Cloudflare Pages, set these as
# Text-typed env vars (NOT Secret) on the Production environment.

# Supabase — public anon credentials (RLS-gated server side).
# These power the Contact Sales form (POSTs to /functions/v1/contact-sales).
VITE_SUPABASE_URL=https://uggsfinugqzjfroxzpbo.supabase.co
VITE_SUPABASE_ANON_KEY=

# Google Analytics 4 Measurement ID
# Get your GA4 ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX. Leave empty to disable analytics entirely.
# Even when set, GA only fires after the visitor accepts cookies via the
# CookieConsent banner.
VITE_GA_MEASUREMENT_ID=

# Cloudflare Turnstile Site Key (bot protection on forms, if re-enabled)
# Get from https://dash.cloudflare.com/?to=/:account/turnstile
# Falls back to Turnstile's public test key if empty (rejects nothing).
VITE_TURNSTILE_SITE_KEY=
